# CAST API configuration. Copy to `.env` and fill in. NEVER commit the real .env.
NODE_ENV=development
CAST_API_PORT=3001

# --- Session (JWT cookie) ---
# Generate: openssl rand -hex 32
CAST_JWT_SECRET=
CAST_JWT_EXPIRES_IN=8h

# --- Active Directory (LDAPS) — primary login, mechanism still open (INIT-0008) ---
# On trt-cast-01's intended network the DCs are 10.20.30.208 / .209.
CAST_LDAP_URL=ldaps://10.20.30.208:636
CAST_LDAP_BASE_DN=DC=triton,DC=local
CAST_LDAP_BIND_DN=CN=cast-svc,OU=Service Accounts,DC=triton,DC=local
CAST_LDAP_BIND_PASSWORD=
# "CAST Users" group — membership REQUIRED to sign in.
CAST_LDAP_ALLOWED_GROUP_DN=CN=CAST Users,OU=Groups,DC=triton,DC=local

# --- Local break-glass admin "TritonAdmin" ---
# Set to control the TritonAdmin password; if blank, a random one is generated
# and printed to the server log once on first boot.
CAST_BREAKGLASS_PASSWORD=

# --- Vessel Location Updating sync (INIT-0012) ---
# node-cron expression (default: top of every hour).
CAST_VESSEL_SYNC_CRON=0 * * * *

# --- aisstream.io (AIS data source, INIT-0012) ---
# WebSocket API. Docs + architecture:
#   knowledge/architecture/vessel-location-updating-aisstream.md
# Get a key at https://aisstream.io (free, GitHub sign-in). SECRET — real value
# goes in .env only, never here.
CAST_AISSTREAM_WS_URL=wss://stream.aisstream.io/v0/stream
CAST_AISSTREAM_API_KEY=

# --- ConnectWise PSA (Manage) REST API (INIT-0002/0012/0014) ---
# Credentialed CW read+write. SECRETS — real values in .env only.
# Pattern: knowledge/architecture/connectwise-api-integration.md
# Use a DEDICATED API Member for CAST (not shared with other integrations).
CW_BASE_URL=https://na.myconnectwise.net/v4_6_release/apis/3.0
CW_COMPANY=
CW_PUBLIC_KEY=
CW_PRIVATE_KEY=
CW_CLIENT_ID=
# Company custom-field captions holding the vessel identifiers
# (verified live 2026-07-23 — the real captions are "Vessel IMO" / "Vessel MMSI"):
CW_IMO_FIELD_CAPTION=Vessel IMO
CW_MMSI_FIELD_CAPTION=Vessel MMSI
# CW company status that further scopes tracking (optional; leave blank = any):
CW_TRACKED_STATUS=
# A vessel = any company whose CW Market contains this (regardless of IMO/MMSI):
CW_VESSEL_MARKET=Yacht
# HARD SAFETY GATE: ConnectWise writes are refused unless this is exactly "true".
CW_WRITES_ENABLED=false
