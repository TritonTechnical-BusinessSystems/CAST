{
  "manifest_version": 3,
  "name": "CAST",
  "short_name": "CAST",
  "description": "ConnectWise Augmentation Suite for Triton — standardizes the ConnectWise PSA UI per role/department.",
  "version": "0.0.1",
  "minimum_chrome_version": "110",
  "key": "",
  "update_url": "https://cast-updates.tritontechnical.com/update-manifest.xml",
  "icons": { "16": "icons/icon16.png", "32": "icons/icon32.png", "48": "icons/icon48.png", "128": "icons/icon128.png" },
  "action": {
    "default_title": "CAST",
    "default_popup": "src/popup/popup.html",
    "default_icon": { "16": "icons/icon16.png", "32": "icons/icon32.png", "48": "icons/icon48.png" }
  },
  "background": { "service_worker": "src/background.js" },
  "permissions": ["storage", "alarms", "scripting", "debugger"],
  "host_permissions": ["https://cast.tritontechnical.com/*"],
  "optional_host_permissions": ["https://*.myconnectwise.net/*"],
  "content_scripts": [
    {
      "matches": ["https://*.myconnectwise.net/*"],
      "js": ["src/content.js"],
      "run_at": "document_idle"
    }
  ]
}
